@page "/square-color"

<PageTitle>Square Color</PageTitle>

<div class="container py-2">
    <div class="row justify-content-center">
        <div class="col-12 text-center">
            <h1 class="h3 h2-md">Indovina il colore della casella</h1>

            <div class="display-3 fw-bold text-uppercase mb-4">@SquareLabel</div>

            <div class="d-flex align-items-center justify-content-center mb-4" style="min-height: 80px;" aria-live="polite">
                @if (ShowCorrectFeedback)
                {
                    <img src="images/happy.svg" alt="Risposta corretta" title="Risposta corretta" class="img-fluid" style="max-height: 160px;" />
                }
                else if (ShowWrongFeedback)
                {
                    <img src="images/sad.svg" alt="Risposta sbagliata" title="Risposta sbagliata" class="img-fluid" style="max-height: 160px;" />
                }
            </div>

            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mb-4">
                <button class="btn btn-light btn-lg px-5 py-3 flex-fill flex-sm-grow-0" @onclick="() => SubmitGuess(true)">Bianco</button>
                <button class="btn btn-dark btn-lg px-5 py-3 flex-fill flex-sm-grow-0" @onclick="() => SubmitGuess(false)">Nero</button>
            </div>

            <div class="fs-5 fw-semibold">
                Risposte corrette: @CorrectAnswerCounter / @AnswerCounter
            </div>
        </div>
    </div>
</div>

@code {
    private static readonly char[] Files = "ABCDEFGH".ToCharArray();
    private readonly Random _random = new();

    private string SquareLabel { get; set; } = "A1";
    private bool CurrentSquareIsWhite { get; set; }

    private int AnswerCounter { get; set; }
    private int CorrectAnswerCounter { get; set; }

    private bool ShowCorrectFeedback { get; set; }
    private bool ShowWrongFeedback { get; set; }

    protected override void OnInitialized()
    {
        NextQuestion();
    }

    private void SubmitGuess(bool guessedWhite)
    {
        AnswerCounter++;

        var isCorrect = guessedWhite == CurrentSquareIsWhite;
        ShowCorrectFeedback = isCorrect;
        ShowWrongFeedback = !isCorrect;

        if (isCorrect)
        {
            CorrectAnswerCounter++;
        }

        NextQuestion();
    }

    private void NextQuestion()
    {
        var fileIndex = _random.Next(0, Files.Length);
        var rank = _random.Next(1, 9);

        var file = Files[fileIndex];
        SquareLabel = $"{file}{rank}";

        // A1 is black, so white squares are where fileIndex + rank is even.
        CurrentSquareIsWhite = (fileIndex + rank) % 2 == 0;
    }
}
