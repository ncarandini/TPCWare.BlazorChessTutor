@page "/square-color"

<PageTitle>Square Color</PageTitle>

<div class="square-quest-page">
    <div class="square-quest-grid">
        <h1 class="square-quest-title">Guess the color of square</h1>

        <div class="square-label">@SquareLabel</div>

        <div class="feedback-zone" aria-live="polite">
            @if (ShowCorrectFeedback)
            {
                <div class="feedback feedback-correct" title="Correct answer">:)</div>
            }
            else if (ShowWrongFeedback)
            {
                <div class="feedback feedback-wrong" title="Wrong answer">:(</div>
            }
        </div>

        <div class="answer-buttons">
            <button class="btn btn-light quest-button" @onclick="() => SubmitGuess(true)">White</button>
            <button class="btn btn-dark quest-button" @onclick="() => SubmitGuess(false)">Black</button>
        </div>

        <div class="score-row">
            <span>Correct answers: @CorrectAnswerCounter / @AnswerCounter</span>
        </div>
    </div>
</div>

@code {
    private static readonly char[] Files = "ABCDEFGH".ToCharArray();
    private readonly Random _random = new();

    private string SquareLabel { get; set; } = "A1";
    private bool CurrentSquareIsWhite { get; set; }

    private int AnswerCounter { get; set; }
    private int CorrectAnswerCounter { get; set; }

    private bool ShowCorrectFeedback { get; set; }
    private bool ShowWrongFeedback { get; set; }

    protected override void OnInitialized()
    {
        NextQuestion();
    }

    private void SubmitGuess(bool guessedWhite)
    {
        AnswerCounter++;

        var isCorrect = guessedWhite == CurrentSquareIsWhite;
        ShowCorrectFeedback = isCorrect;
        ShowWrongFeedback = !isCorrect;

        if (isCorrect)
        {
            CorrectAnswerCounter++;
        }

        NextQuestion();
    }

    private void NextQuestion()
    {
        var fileIndex = _random.Next(0, Files.Length);
        var rank = _random.Next(1, 9);

        var file = Files[fileIndex];
        SquareLabel = $"{file}{rank}";

        // A1 is black, so white squares are where fileIndex + rank is even.
        CurrentSquareIsWhite = (fileIndex + rank) % 2 == 0;
    }
}
